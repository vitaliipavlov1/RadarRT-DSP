# aarch64-linux-gnu.cmake.example
#
# Cross-compilation toolchain template for an Embedded Linux ARM64 target.
# Copy to a real .cmake file, adjust the paths/sysroot for your SDK, and use:
#
#   cmake -B build/arm64 -DCMAKE_TOOLCHAIN_FILE=cmake/toolchains/aarch64-linux-gnu.cmake
#
# Native builds are the default; this template is only needed to cross-compile.

# set(CMAKE_SYSTEM_NAME Linux)
# set(CMAKE_SYSTEM_PROCESSOR aarch64)
#
# set(CMAKE_C_COMPILER   aarch64-linux-gnu-gcc)
# set(CMAKE_CXX_COMPILER aarch64-linux-gnu-g++)
#
# set(CMAKE_SYSROOT /path/to/sysroot)
#
# set(CMAKE_FIND_ROOT_PATH_MODE_PROGRAM NEVER)
# set(CMAKE_FIND_ROOT_PATH_MODE_LIBRARY ONLY)
# set(CMAKE_FIND_ROOT_PATH_MODE_INCLUDE ONLY)
# set(CMAKE_FIND_ROOT_PATH_MODE_PACKAGE ONLY)
